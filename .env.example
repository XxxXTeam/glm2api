# =========================
# glm2api 示例配置
# =========================
# 使用方式：
# 1. 复制本文件为 `.env`
# 2. 至少填写 `GLM_REFRESH_TOKEN`
# 3. 按需修改监听地址、开放模型、服务鉴权等配置

# ---------------------------------
# 服务监听配置
# ---------------------------------
# 服务监听地址。
# 本机自用通常填 127.0.0.1；局域网共享可以改为 0.0.0.0。
HOST=127.0.0.1

# 服务端口。
# OpenAI SDK 常见写法会连到 http://127.0.0.1:8000/v1，所以默认保持 8000。
PORT=8000

# OpenAI 兼容接口前缀。
# 一般保持 /v1 即可，除非你已有反向代理规则。
API_PREFIX=/v1

# 日志级别：DEBUG / INFO / WARNING / ERROR
# 想看详细请求过程可改成 DEBUG。
LOG_LEVEL=INFO

# 上游请求超时时间，单位秒。
# GLM Web 端在长回答和联网场景下会比较慢，默认给 120 秒更稳妥。
REQUEST_TIMEOUT_SECONDS=120

# CORS 允许来源。
# 前端本地调试可保留 *；若要收紧来源，可改成具体域名。
CORS_ALLOW_ORIGIN=*

# ---------------------------------
# 本服务自身鉴权（可选）
# ---------------------------------
# 如果你希望别人访问本地代理时也必须带 Bearer Token，可以在这里配置。
# 多个 key 用英文逗号分隔，例如：
# SERVER_API_KEYS=sk-local-1,sk-local-2
# 留空表示不校验访问者。
SERVER_API_KEYS=

# ---------------------------------
# GLM / 智谱清言上游配置
# ---------------------------------
# 必填。
# 这里填写你从 chatglm.cn 网页端拿到的 refresh_token。
# 当前实现会用它换取短期 access_token，再转发实际请求。
# 如果上游返回了新的 refresh_token，服务会自动写回当前 `.env` 文件。
GLM_REFRESH_TOKEN=

# GLM Web 端基础地址。
# 默认已经对应 docs 中的 chatglm Web 接口，不建议修改。
GLM_BASE_URL=https://chatglm.cn/chatglm

# 默认 assistant_id
# docs 里使用的是 65940acff94777010aa6b796
# 大多数场景保留默认即可；如果你有自己的专属助手，也可以替换
GLM_ASSISTANT_ID=65940acff94777010aa6b796

# 图片生成接口默认使用的绘图 assistant_id
GLM_IMAGE_ASSISTANT_ID=65a232c082ff90a2ad2f15e2

# 对外暴露给 OpenAI 客户端使用的绘图模型名。
# 默认使用 glm-image-1
GLM_IMAGE_MODEL_NAME=glm-image-1

# 是否在每次回答后删除 GLM 会话。
# true: 更干净，减少网页端聊天记录堆积
# false: 保留会话，方便你在上游网页端排查
GLM_DELETE_CONVERSATION=true

# 多请求排队最大等待时间，单位秒。
# 由于 GLM Web 端同一账号经常只允许一个对话同时生成，
# 建议保留较大的等待时间，让本地并发请求按顺序排队。
GLM_QUEUE_WAIT_TIMEOUT_SECONDS=600

# 当 GLM 返回“请等待其他对话生成完毕”时，最多自动重试多少次。
# 这个重试主要用于兜住“网页端还有其他会话在生成”的情况。
GLM_BUSY_MAX_RETRIES=30

# 触发上面的忙碌重试时，两次重试之间等待多久，单位秒。
GLM_BUSY_RETRY_INTERVAL_SECONDS=2

# 自定义 User-Agent。
# 只有在你明确知道要伪装成其他浏览器时再改。
GLM_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/143.0.0.0 Safari/537.36 Edg/143.0.0.0

# ---------------------------------
# 暴露给客户端的模型列表
# ---------------------------------
# `/v1/models` 返回哪些模型名，由这里控制。
# 这只是“对外展示名”，不一定等于上游真实 assistant_id。
EXPOSED_MODELS=glm-5,glm-4,glm-4-flash,glm-4-air,glm-4v,glm-zero-preview,glm-deep-research,glm-image-1

# 模型别名映射。
# 格式：对外模型名=上游模型名或 assistant_id，多个用英文逗号分隔。
# 说明：
# 1. 左边给 OpenAI SDK/客户端使用
# 2. 右边如果是 24 位以上字母数字串，会直接当作 assistant_id
# 3. 右边如果不是 assistant_id，则仍会走默认 GLM_ASSISTANT_ID，但保留原模型名用于模式判断
# 示例：
# GLM_MODEL_ALIASES=glm-4=glm-4,glm-custom=67abcdef0123456789abcd12
GLM_MODEL_ALIASES=glm-5=glm-5,glm-4=glm-4,glm-4-flash=glm-4-flash,glm-4-air=glm-4-air,glm-4v=glm-4v,glm-zero-preview=glm-zero-preview,glm-deep-research=glm-deep-research,glm-image-1=glm-image-1
